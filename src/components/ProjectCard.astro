---
import Tag from './Tag.astro';

interface Props {
  id: string;
  title: string;
  problem: string;
  description: string;
  stack: string[];
  github?: string;
}
const { id, title, problem, description, stack, github } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<div class="card bg-base-100 border border-base-300 reveal">
  <div class="card-body gap-3">
    <div class="flex items-start justify-between gap-3">
      <h3 class="card-title font-display text-lg">{title}</h3>
      {github && (
        <a href={github} target="_blank" rel="noopener" aria-label="Ver repositorio en GitHub"
          class="shrink-0 mt-1 text-base-content/40 hover:text-base-content transition-colors">
          <svg viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" clip-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" /></svg>
        </a>
      )}
    </div>
    <p class="font-display italic text-base-content">{problem}</p>
    <p class="text-base-content/70 text-sm">{description}</p>
    <div class="flex flex-wrap gap-2">
      {stack.map((s) => <Tag label={s} />)}
    </div>
    <div class="card-actions mt-2">
      <a href={`${base}/proyectos/${id}/`} class="link text-secondary font-semibold text-sm">Ver caso completo →</a>
    </div>
  </div>
</div>
