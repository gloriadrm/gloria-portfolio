---
import Tag from './Tag.astro';
import StatusBadge from './StatusBadge.astro';

interface Props {
  id: string;
  title: string;
  status: 'progress' | 'done';
  statusLabel: string;
  problem: string;
  description: string;
  stack: string[];
}
const { id, title, status, statusLabel, problem, description, stack } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<div class="card bg-base-100 border border-base-300 reveal">
  <div class="card-body gap-3">
    <div class="flex items-start justify-between gap-3">
      <h3 class="card-title font-display text-lg">{title}</h3>
      <StatusBadge status={status} label={statusLabel} />
    </div>
    <p class="font-display italic text-base-content">{problem}</p>
    <p class="text-base-content/70 text-sm">{description}</p>
    <div class="flex flex-wrap gap-2">
      {stack.map((s) => <Tag label={s} />)}
    </div>
    <div class="card-actions mt-2">
      <a href={`${base}/proyectos/${id}/`} class="link text-secondary font-semibold text-sm">Ver caso completo →</a>
    </div>
  </div>
</div>
