---
interface Props {
  status: 'progress' | 'done';
  label: string;
}
const { status, label } = Astro.props;
const cls = status === 'done'
  ? 'bg-success/15 text-success'
  : 'bg-base-200 text-primary';
---
<span class={`badge badge-sm font-label uppercase tracking-wide ${cls} border-none`}>{label}</span>
