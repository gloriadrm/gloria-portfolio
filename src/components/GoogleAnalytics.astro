---
// Google tag (gtag.js). No se renderiza nada si PUBLIC_GA_MEASUREMENT_ID no está
// definida (por ejemplo, en local sin .env) — evita mandar un tag roto o vacío.
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---
{gaId && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}
