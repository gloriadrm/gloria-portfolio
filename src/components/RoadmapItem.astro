---
import Tag from './Tag.astro';

interface Props {
  title: string;
  problem: string;
  stack: string[];
}
const { title, problem, stack } = Astro.props;
---
<div class="py-5 border-b border-base-300 last:border-none reveal">
  <h3 class="font-display text-base mb-1">{title}</h3>
  <p class="text-base-content/70 text-sm mb-2 max-w-xl">{problem}</p>
  <div class="flex flex-wrap gap-2">
    {stack.map((s) => <Tag label={s} />)}
  </div>
</div>
