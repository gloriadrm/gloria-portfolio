---
import site from '../data/site.json';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Portfolio de Gloria del Rio Márquez.' } = Astro.props;

// Normalizado sin barra final: siempre escribimos `${base}/ruta` a partir de aquí.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600&family=Inter:wght@400;500;600&family=Space+Mono&display=swap" rel="stylesheet" />
  <link rel="icon" href={`${base}/favicon.svg`} />
  <script is:inline>
    // Se ejecuta antes de pintar para evitar el parpadeo del tema por
    // defecto al navegar entre páginas (el sitio es multipágina, no SPA).
    (function () {
      try {
        if (localStorage.getItem('gloria-theme') === 'gloria-dark') {
          document.documentElement.setAttribute('data-theme', 'gloria-dark');
        }
      } catch (e) {}
    })();
  </script>
</head>
<body class="bg-base-100 text-base-content min-h-screen flex flex-col">

  <header class="navbar bg-base-100/90 backdrop-blur border-b border-base-300 sticky top-0 z-50">
    <div class="max-w-5xl w-full mx-auto px-6 flex items-center justify-between">
      <a href={`${base}/`} class="font-display font-semibold text-lg">
        {site.logoFirst} <span class="text-primary">{site.logoLast}</span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        <a href={`${base}/sobre-mi/`} class="btn btn-ghost btn-sm font-normal">Sobre mí</a>
        <a href={`${base}/proyectos/`} class="btn btn-ghost btn-sm font-normal">Proyectos</a>
        <a href={`${base}/#contact`} class="btn btn-ghost btn-sm font-normal">Contacto</a>
        <label class="swap swap-rotate btn btn-ghost btn-sm btn-circle ml-1" aria-label="Cambiar a tema oscuro">
          <input type="checkbox" class="theme-controller" value="gloria-dark" />
          <svg class="swap-off h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Z"/></svg>
          <svg class="swap-on h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22a8.09,8.09,0,0,1,.7-1.2,10.11,10.11,0,0,0,10,10,10.14,10.14,0,0,0,1.2-.07A8.13,8.13,0,0,1,12.14,19.73Z"/></svg>
        </label>
      </div>

      <div class="md:hidden flex items-center gap-1">
        <label class="swap swap-rotate btn btn-ghost btn-sm btn-circle" aria-label="Cambiar a tema oscuro">
          <input type="checkbox" class="theme-controller" value="gloria-dark" />
          <svg class="swap-off h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Z"/></svg>
          <svg class="swap-on h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22a8.09,8.09,0,0,1,.7-1.2,10.11,10.11,0,0,0,10,10,10.14,10.14,0,0,0,1.2-.07A8.13,8.13,0,0,1,12.14,19.73Z"/></svg>
        </label>
        <details class="dropdown dropdown-end">
          <summary class="btn btn-ghost btn-sm list-none">☰</summary>
          <ul class="menu dropdown-content bg-base-100 rounded-box z-20 w-64 p-2 shadow-md border border-base-300 mt-2">
            <li><a href={`${base}/sobre-mi/`}>Sobre mí</a></li>
            <li><a href={`${base}/proyectos/`}>Proyectos</a></li>
            <li><a href={`${base}/#contact`}>Contacto</a></li>
          </ul>
        </details>
      </div>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="border-t border-base-300 py-8 text-center text-sm text-base-content/60">
    <div class="max-w-5xl mx-auto px-6">
      © {new Date().getFullYear()} {site.name} · <a href={`${base}/sobre-mi/`} class="link">Sobre mí</a>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in'); });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    // Sincroniza el toggle claro/oscuro (nav de escritorio + móvil) con
    // localStorage para que la preferencia persista al navegar entre páginas.
    const themeToggles = document.querySelectorAll<HTMLInputElement>('.theme-controller');
    const storedTheme = localStorage.getItem('gloria-theme');
    themeToggles.forEach((cb) => {
      cb.checked = storedTheme === 'gloria-dark';
      cb.addEventListener('change', () => {
        const theme = cb.checked ? 'gloria-dark' : 'gloria';
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('gloria-theme', theme);
        themeToggles.forEach((other) => { if (other !== cb) other.checked = cb.checked; });
      });
    });
  </script>
</body>
</html>
