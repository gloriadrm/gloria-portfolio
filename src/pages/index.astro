---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBg from '../components/HeroBg.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import ProjectCard from '../components/ProjectCard.astro';
import site from '../data/site.json';
import { AnalyticsEvent } from '../lib/events';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const proyectos = (await getCollection('proyectos')).sort((a, b) => a.data.order - b.data.order);
const featured = proyectos[0];
const latest = proyectos.slice(1);
---
<BaseLayout title={`${site.name} — Ingeniera de Datos`}>

  <!-- HERO: una pantalla, nada más -->
  <section class="relative overflow-hidden border-b border-base-300 min-h-[calc(100vh-4rem)] flex items-center">
    <HeroBg />
    <div class="relative z-10 max-w-5xl w-full mx-auto px-6 py-10">
      <div class="max-w-3xl">
        <span class="block font-label text-xs tracking-widest uppercase text-primary mb-4">{site.eyebrow}</span>
        <div class="font-display font-semibold text-lg text-secondary mb-2">{site.name}</div>
        <h1 class="font-display text-4xl leading-tight mb-3 whitespace-pre-line">{site.heroTitle}</h1>
        <p class="font-display text-lg md:text-xl text-secondary mb-5 max-w-md">{site.heroSubtitle}</p>
        <p class="text-base-content/70 text-lg mb-8 max-w-md">{site.heroLead}</p>
        <div class="flex flex-wrap items-center gap-4 mb-7">
          <a href="#featured" class="btn btn-neutral rounded-full">Ver proyectos</a>
          <a href={`${base}/${site.cvFile}`} download class="btn btn-outline btn-neutral rounded-full">Descargar CV</a>
        </div>
        <div class="flex gap-5 font-label text-sm text-base-content/60">
          <a href={site.github} target="_blank" rel="noopener" class="link">GitHub ↗</a>
          <a href={site.linkedin} target="_blank" rel="noopener" class="link">LinkedIn ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROYECTO DESTACADO -->
  <section id="featured" class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="mb-10 reveal">
        <span class="block font-label text-xs tracking-widest uppercase text-primary mb-2">Portfolio técnico</span>
        <h2 class="font-display text-2xl mb-2">Último proyecto</h2>
        <p class="text-base-content/70 max-w-xl">Pocos proyectos, explicados a fondo: problema, arquitectura, decisiones y aprendizajes — no una lista larga de repositorios.</p>
      </div>
      {featured && (
        <FeaturedProject
          id={featured.id}
          title={featured.data.title}
          problem={featured.data.problem}
          description={featured.data.description}
          stack={featured.data.stack}
          competencias={featured.data.competencias}
          github={featured.data.github}
        />
      )}
    </div>
  </section>

  <!-- ÚLTIMOS PROYECTOS: aparece solo si hay más de uno -->
  {latest.length > 0 && (
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="mb-10 reveal">
          <span class="block font-label text-xs tracking-widest uppercase text-primary mb-2">Más casos</span>
          <h2 class="font-display text-2xl">Otros proyectos</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {latest.map((p) => (
            <ProjectCard
              id={p.id}
              title={p.data.title}
              problem={p.data.problem}
              description={p.data.description}
              stack={p.data.stack}
              github={p.data.github}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CONTACT -->
  <section id="contact" class="py-16 border-t border-base-300">
    <div class="max-w-5xl mx-auto px-6">
      <div class="mb-8 reveal">
        <span class="block font-label text-xs tracking-widest uppercase text-primary mb-2">Hablemos</span>
        <h2 class="font-display text-2xl">Contacto</h2>
      </div>
      <div class="card bg-base-100 border border-base-300 reveal">
        <div class="card-body items-center text-center gap-4 py-10">
          <p class="text-base-content/70 max-w-md">¿Buscas incorporar talento en Data Engineering o IA? Estoy disponible para nuevas oportunidades.</p>
          <div class="flex flex-wrap justify-center gap-6 font-semibold text-secondary">
            <a href={`mailto:${site.email}`} class="link">{site.email}</a>
            <a href={`tel:${site.phone}`} class="link">{site.phoneDisplay}</a>
            <a href={site.linkedin} target="_blank" rel="noopener" class="link" data-analytics-event={AnalyticsEvent.LINKEDIN_CLICK}>LinkedIn</a>
            <a href={site.github} target="_blank" rel="noopener" class="link">GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
